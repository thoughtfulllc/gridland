{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@opentui/core": ["../../packages/core/src/index.ts"],
      "@opentui/core/*": ["../../packages/core/src/*"],
      "@opentui/react": ["../../packages/core/src/react/index.ts"]
    }
  },
  "include": ["src", "gridland-jsx.d.ts"]
}
