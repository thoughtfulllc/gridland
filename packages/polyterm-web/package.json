{
  "name": "@polyterm.io/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./next-plugin": {
      "types": "./dist/next-plugin.d.ts",
      "import": "./dist/next-plugin.js",
      "require": "./dist/next-plugin.cjs"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "test": "bun test --preload ./test/preload.ts",
    "test:ci": "bun test --preload ./test/preload.ts --randomize --rerun-each 3"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "events": "^3.3.0",
    "marked": "^17.0.3",
    "react": "^19.0.0",
    "react-reconciler": "^0.32.0",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^17.4.4",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  }
}
