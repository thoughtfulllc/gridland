{
  "name": "opentui-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "demo": "bun run --preload ../opentui-web/test/preload.ts scripts/demo.tsx",
    "test": "bun test --preload ../opentui-web/test/preload.ts",
    "test:ci": "bun test --preload ../opentui-web/test/preload.ts --randomize --rerun-each 3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "figlet": "^1.10.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  }
}
