{
  "name": "@gridland/ui",
  "version": "0.2.56",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./components/index.ts"
  },
  "scripts": {
    "build": "bun run scripts/build-registry.ts",
    "demo": "bun run --tsconfig-override ./tsconfig.json scripts/demo.tsx",
    "test": "bun test --preload ../web/test/preload.ts",
    "test:update-snapshots": "bun test --preload ../web/test/preload.ts --update-snapshots",
    "test:ci": "bun test --preload ../web/test/preload.ts --randomize --rerun-each 3"
  },
  "devDependencies": {
    "@gridland/utils": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.0.0",
    "figlet": "^1.10.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "@gridland/utils": ">=0.3.0"
  }
}
