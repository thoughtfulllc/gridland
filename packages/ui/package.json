{
  "name": "@gridland/ui",
  "version": "0.2.8",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "demo": "bun run --tsconfig-override ./tsconfig.json scripts/demo.tsx",
    "test": "bun test --preload ../web/test/preload.ts",
    "test:ci": "bun test --preload ../web/test/preload.ts --randomize --rerun-each 3"
  },
  "devDependencies": {
    "@opentui/core": "^0.1.86",
    "@opentui/react": "^0.1.86",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.0.0",
    "figlet": "^1.10.0",
    "react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "@opentui/react": ">=0.1.86",
    "@opentui/core": ">=0.1.86"
  }
}
