{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@gridland/ui": ["./components/index.ts"],
      "@/registry/gridland/ui/*": ["./components/*"],
      "@/registry/gridland/lib/*": ["./lib/*"],
      "@/registry/gridland/hooks/*": ["./hooks/*"]
    }
  },
  "include": ["components", "lib", "hooks", "scripts", "../demo/src/landing", "gridland-jsx.d.ts"]
}
