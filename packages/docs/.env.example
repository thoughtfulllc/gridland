# URL of the Cloudflare Worker chat proxy
# Local dev: run `bun run worker:dev` from the repo root, then use:
NEXT_PUBLIC_CHAT_API_URL=http://localhost:8787
# Production: set this to your deployed worker URL in Vercel dashboard
# NEXT_PUBLIC_CHAT_API_URL=https://gridland-chat-proxy.<your-account>.workers.dev
