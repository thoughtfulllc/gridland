{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "fumadocs-mdx:collections/*": [
        "./.source/*"
      ],
      "opentui-web": [
        "../web/src/index.ts"
      ],
      "@gridland/web": [
        "../web/src/index.ts"
      ],
      "opentui-ui": [
        "../ui/components/index.ts"
      ],
      "@gridland/ui": [
        "../ui/components/index.ts"
      ],
      "@gridland/demo/landing": [
        "../demo/src/landing/index.ts"
      ],
      "@demos/*": [
        "../demo/demos/*"
      ]
    }
  },
  "include": [
    "**/*.mdx",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".source/**/*.ts",
    "gridland-jsx.d.ts",
    "next-env.d.ts",
    "dist/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
