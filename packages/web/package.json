{
  "name": "@gridland/web",
  "version": "0.4.2",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./next-plugin": {
      "types": "./dist/next-plugin.d.ts",
      "import": "./dist/next-plugin.js",
      "require": "./dist/next-plugin.cjs"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./jsx": {
      "types": "./src/gridland-jsx.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/shims",
    "src/gridland-jsx.d.ts"
  ],
  "sideEffects": [
    "./src/components/register.ts",
    "./dist/index.js"
  ],
  "scripts": {
    "build": "tsup; node build-browser.mjs",
    "dev": "vite",
    "test": "bun test --preload ./test/preload.ts",
    "types:check": "tsc --noEmit --project test/type-check",
    "test:ci": "bun test --preload ./test/preload.ts --randomize --rerun-each 3",
    "prepublishOnly": "bun ../../scripts/check-versions.mjs"
  },
  "dependencies": {
    "@gridland/utils": "workspace:*",
    "diff": "^8.0.3",
    "events": "^3.3.0",
    "marked": "^17.0.3",
    "react": "^19.0.0",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^17.4.4",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.27.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-reconciler": "0.33.0"
  }
}
